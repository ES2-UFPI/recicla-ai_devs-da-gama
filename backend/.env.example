## Alternância entre Atlas e Mongo local
# Coloque true para usar o Atlas; false para usar o Mongo local em Docker
USE_ATLAS=false

## URI local (aponta para o serviço "mongodb" do docker-compose)
MONGO_URI_LOCAL=mongodb://admin:admin123@mongodb:27017/ReciclaAi?authSource=admin

## URI do Atlas (preencha com suas credenciais)
MONGO_URI_ATLAS=mongodb+srv://<db_user>:<db_password>@recicla-ai.r0plgd6.mongodb.net/ReciclaAi?retryWrites=true&w=majority&tls=true&appName=Recicla-Ai

## Compatibilidade (opcional): URI única
# MONGO_URI=

DB_NAME=ReciclaAi

MONGO_APP_NAME=recicla-ai-backend

## JWT Configuration
# Chave secreta para assinar tokens JWT (MUDE EM PRODUÇÃO!)
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))" para gerar
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars-please

# Algoritmo de assinatura JWT
JWT_ALGORITHM=HS256

# Tempo de expiração do access token (em minutos)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Tempo de expiração do refresh token (em dias)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

## Cookie Configuration
# Domínio dos cookies (localhost para dev, seu domínio em prod)
COOKIE_DOMAIN=localhost

# Usar cookies seguros (true apenas com HTTPS em produção)
COOKIE_SECURE=false

# Política SameSite (lax, strict ou none)
COOKIE_SAMESITE=lax

## Development Endpoints Configuration
# Habilita endpoints de desenvolvimento (/dev/*)
# IMPORTANTE: Sempre defina como false em produção!
ENABLE_DEV_ENDPOINTS=true
