## ⚠️ CONFIGURAÇÃO DE PRODUÇÃO ⚠️
## Copie este arquivo para .env na hora do deploy em produção

## Usar MongoDB Atlas (sempre true em produção)
USE_ATLAS=true

## URI do Atlas (substitua com suas credenciais reais)
MONGO_URI_ATLAS=mongodb+srv://<db_user>:<db_password>@recicla-ai.r0plgd6.mongodb.net/ReciclaAi?retryWrites=true&w=majority&tls=true&appName=Recicla-Ai

DB_NAME=ReciclaAi
MONGO_APP_NAME=recicla-ai-backend

## JWT Configuration
# ⚠️ IMPORTANTE: Gere uma chave secreta forte e única!
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=SUBSTITUA-POR-CHAVE-SECRETA-FORTE-GERADA

JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

## Cookie Configuration
# Domínio do seu app em produção (ex: api.reciclaai.com)
COOKIE_DOMAIN=api.reciclaai.com

# ⚠️ SEMPRE true em produção (requer HTTPS)
COOKIE_SECURE=true

# Política SameSite para produção
COOKIE_SAMESITE=lax

## Development Endpoints Configuration
# ⚠️ CRÍTICO: SEMPRE false em produção!
# Endpoints /dev/* são para desenvolvimento apenas
ENABLE_DEV_ENDPOINTS=false
